<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-permission android:name="android.permission.CAMERA" />
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
  <uses-feature
    android:name="android.hardware.camera.front"
    android:required="false" />

  <application
    android:allowBackup="true"
    android:networkSecurityConfig="@xml/network_security_config"
    android:usesCleartextTraffic="false"
    android:icon="@drawable/ic_driveedge"
    android:label="@string/app_name"
    android:roundIcon="@drawable/ic_driveedge"
    android:supportsRtl="true"
    android:theme="@style/Theme.DriveEdge">

    <activity
      android:name="com.driveedge.app.ui.MainActivity"
      android:exported="false" />

    <activity
      android:name="com.driveedge.app.ui.VehicleWaitingActivity"
      android:exported="false" />

    <activity
      android:name="com.driveedge.app.ui.EdgeDisabledActivity"
      android:exported="false" />

    <activity
      android:name="com.driveedge.app.ui.BindPendingActivity"
      android:exported="false" />

    <activity
      android:name="com.driveedge.app.ui.BindEnterpriseActivity"
      android:exported="false" />

    <activity
      android:name="com.driveedge.app.ui.SignInActivity"
      android:exported="false" />

    <activity
      android:name="com.driveedge.app.ui.EdgeLaunchActivity"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

  </application>

</manifest>
