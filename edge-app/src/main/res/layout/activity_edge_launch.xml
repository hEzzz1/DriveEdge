<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center"
  android:orientation="vertical"
  android:padding="24dp">

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:text="@string/app_name"
    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

  <TextView
    android:id="@+id/launchStatusView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:text="@string/edge_launch_ready"
    android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:text="@string/edge_launch_device_code"
    android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

  <TextView
    android:id="@+id/deviceCodeView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
    android:textIsSelectable="true" />

  <EditText
    android:id="@+id/enterpriseActivationCodeInput"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:hint="@string/edge_enterprise_activation_code_hint"
    android:inputType="text"
    android:maxLines="1" />

  <Button
    android:id="@+id/scanQrButton"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:text="@string/edge_scan_qr" />

  <Button
    android:id="@+id/claimButton"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:text="@string/edge_launch_retry" />

  <Button
    android:id="@+id/resetButton"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:text="@string/edge_launch_reset" />
</LinearLayout>
